{
  "name": "pi-bash-viewer",
  "version": "0.1.1",
  "description": "A pi extension that adds optional PTY-backed live terminal rendering to the bash tool via usePTY=true.",
  "type": "module",
  "author": "Lucas Meijer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/broeh/pi-bash-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/broeh/pi-bash-viewer/issues"
  },
  "homepage": "https://github.com/broeh/pi-bash-viewer#readme",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "bash",
    "pty",
    "terminal",
    "tui"
  ],
  "files": [
    "index.ts",
    "pty-execute.ts",
    "pty-kill.ts",
    "pty-session.ts",
    "spawn-helper.ts",
    "truncate.ts",
    "widget.ts",
    "overlay.ts",
    "panel.ts",
    "settings.ts",
    "terminal-emulator.ts",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --import tsx --test tests/*.test.mjs"
  },
  "dependencies": {
    "@xterm/headless": "^5.5.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^24.3.0",
    "strip-ansi": "^7.1.0",
    "tsx": "^4.21.0",
    "typebox": "^1.1.24",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  }
}
